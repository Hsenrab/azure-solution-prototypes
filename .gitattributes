# Enforce consistent line endings across OSes.
# Repo-wide default: text files are auto-detected and stored/checked out as LF.
* text=auto eol=lf

# Explicit LF for common text formats (defensive, in case autodetection differs).
*.ipynb  text eol=lf
*.py     text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.jsonl  text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.bicep  text eol=lf
*.sh     text eol=lf

# Windows-only scripts stay CRLF.
*.ps1    text eol=crlf
*.psm1   text eol=crlf
*.psd1   text eol=crlf
*.cmd    text eol=crlf
*.bat    text eol=crlf

# Binary formats — never touch.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.xlsx   binary
*.docx   binary
*.pptx   binary
*.wav    binary
*.mp3    binary
*.mp4    binary
