{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "17866157790986658547"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "swedencentral",
      "metadata": {
        "description": "Azure region for resources"
      }
    },
    "demoId": {
      "type": "string",
      "defaultValue": "gpt4o01",
      "metadata": {
        "description": "Demo ID used for deterministic naming"
      }
    },
    "uniqueSuffix": {
      "type": "string",
      "defaultValue": "[uniqueString(subscription().id, resourceGroup().id)]",
      "metadata": {
        "description": "Optional suffix to avoid naming collisions"
      }
    },
    "deploymentName": {
      "type": "string",
      "defaultValue": "gpt-4o",
      "metadata": {
        "description": "Model deployment name used by notebooks"
      }
    },
    "modelName": {
      "type": "string",
      "defaultValue": "gpt-4o",
      "metadata": {
        "description": "Model name for the deployment"
      }
    },
    "modelVersion": {
      "type": "string",
      "defaultValue": "2024-11-20",
      "metadata": {
        "description": "Model version for the deployment"
      }
    },
    "deploymentCapacityK": {
      "type": "int",
      "defaultValue": 100,
      "metadata": {
        "description": "Deployment capacity in thousands of tokens per minute"
      }
    },
    "projectDisplayName": {
      "type": "string",
      "defaultValue": "GPT4o Prototype Project",
      "metadata": {
        "description": "Display name for Foundry project"
      }
    }
  },
  "variables": {
    "normalizedDemoId": "[toLower(replace(parameters('demoId'), '-', ''))]",
    "accountName": "[take(format('ai{0}{1}', variables('normalizedDemoId'), take(parameters('uniqueSuffix'), 5)), 24)]",
    "projectName": "[format('proj-{0}', toLower(parameters('demoId')))]",
    "disableLocalAuthForDemo": false
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-06-01",
      "name": "[variables('accountName')]",
      "location": "[parameters('location')]",
      "kind": "AIServices",
      "identity": {
        "type": "SystemAssigned"
      },
      "sku": {
        "name": "S0"
      },
      "properties": {
        "allowProjectManagement": true,
        "customSubDomainName": "[variables('accountName')]",
        "disableLocalAuth": "[variables('disableLocalAuthForDemo')]",
        "publicNetworkAccess": "Enabled",
        "restrictOutboundNetworkAccess": false
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', variables('accountName'), parameters('deploymentName'))]",
      "sku": {
        "name": "GlobalStandard",
        "capacity": "[parameters('deploymentCapacityK')]"
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "[parameters('modelName')]",
          "version": "[parameters('modelVersion')]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('accountName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/projects",
      "apiVersion": "2025-06-01",
      "name": "[format('{0}/{1}', variables('accountName'), variables('projectName'))]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "description": "Prototype project for validating GPT-4o multimodal workflows in a Foundry-aligned setup.",
        "displayName": "[parameters('projectDisplayName')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('accountName'))]"
      ]
    }
  ],
  "outputs": {
    "location": {
      "type": "string",
      "value": "[parameters('location')]"
    },
    "resourceGroupName": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "aiServicesAccountName": {
      "type": "string",
      "value": "[variables('accountName')]"
    },
    "aiServicesEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', variables('accountName')), '2025-06-01').endpoint]"
    },
    "aiDeploymentName": {
      "type": "string",
      "value": "[parameters('deploymentName')]"
    },
    "foundryProjectName": {
      "type": "string",
      "value": "[variables('projectName')]"
    },
    "foundryProjectEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts/projects', variables('accountName'), variables('projectName')), '2025-06-01').endpoints['AI Foundry API']]"
    }
  }
}