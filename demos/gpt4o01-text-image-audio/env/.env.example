# This file documents the expected variables.
# The actual env/.env is written automatically by 01_deploy_infra.ipynb
# after the Bicep deployment completes. Never commit env/.env.
#
# Standard new Azure AI Foundry (kind: AIServices) variable names.
# Populate with values specific to your demo below.

AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=swedencentral
AZURE_ACCOUNT_NAME=
AZURE_AI_ENDPOINT=https://<account-name>.services.ai.azure.com/
AZURE_AUTH_MODE=aad
AZURE_AI_DEPLOYMENT=gpt-4o
AZURE_SPEECH_VOICE=en-US-JennyNeural

# Local media file inputs used by test notebooks.
# Keep these values relative to the demo root for portability.
LOCAL_IMAGE_PATH=./data/sample-image.png
LOCAL_AUDIO_PATH=./data/sample-audio.wav
