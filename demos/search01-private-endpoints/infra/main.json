      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
    },
    "snetPePrefix": {
      "type": "string",
      "value": "[parameters('privateEndpointSubnetPrefix')]"
    },
    "vpnClientAddressPool": {
      "type": "string",
      "value": "[parameters('vpnClientAddressPool')]"
    },
    "resourceGroupName": {
