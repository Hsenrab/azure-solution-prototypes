        "[resourceId('Microsoft.Network/privateEndpoints', format('pe-{0}-search', variables('searchServiceName')))]"
      ]
    },
    {
      "type": "Microsoft.Search/searchServices/sharedPrivateLinkResources",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', variables('searchServiceName'), 'storage-blob-splr')]",
      "properties": {
        "privateLinkResourceId": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
        "groupId": "blob",
        "requestMessage": "Allow Search managed identity blob access over shared private link for this demo."
