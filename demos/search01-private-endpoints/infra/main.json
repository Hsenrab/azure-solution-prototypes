    "adminPublicKey": {
      "type": "string",
      "defaultValue": "ssh-rsa  demo@search01",
      "metadata": {
        "description": "SSH public key for DNS VM admin account"
      }
    }
  },
  "variables": {
    "uniqueSuffix": "[take(uniqueString(subscription().id, resourceGroup().id), 5)]",
    "normalizedDemoId": "[toLower(replace(parameters('demoId'), '-', ''))]",
    "storageAccountName": "[take(format('st{0}{1}', variables('normalizedDemoId'), variables('uniqueSuffix')), 24)]",
    "searchServiceName": "[take(format('srch-{0}-{1}', variables('normalizedDemoId'), variables('uniqueSuffix')), 60)]",
    "vnetName": "vnet-search01",
    "vnetGatewayName": "vpngw-search01",
