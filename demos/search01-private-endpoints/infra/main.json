              "access": "Allow",
              "direction": "Inbound",
              "priority": 100,
              "protocol": "Udp",
              "sourceAddressPrefix": "[parameters('vpnClientAddressPool')]",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "53"
            }
          },
          {
            "name": "allow-dns-tcp-from-vpn-pool",
            "properties": {
              "access": "Allow",
              "direction": "Inbound",
              "priority": 110,
              "protocol": "Tcp",
              "sourceAddressPrefix": "[parameters('vpnClientAddressPool')]",
              "sourcePortRange": "*",
              "destinationAddressPrefix": "*",
              "destinationPortRange": "53"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "pip-search01-dns",
