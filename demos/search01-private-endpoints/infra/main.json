      "properties": {
        "disableLocalAuth": true,
        "publicNetworkAccess": "disabled",
        "semanticSearch": "free",
        "replicaCount": 1,
        "partitionCount": 1,
        "hostingMode": "default"
      }
    },
    {
      "type": "Microsoft.Network/privateDnsZones",
      "apiVersion": "2020-06-01",
      "name": "privatelink.blob.core.windows.net",
