        "description": "Azure region for all resources"
      }
    },
    "demoId": {
      "type": "string",
      "defaultValue": "search01-private-endpoints",
      "metadata": {
        "description": "Demo ID used for naming"
      }
    },
    "tenantId": {
      "type": "string",
      "metadata": {
        "description": "AAD tenant ID for VPN auth settings"
      }
    },
    "deployerPrincipalId": {
      "type": "string",
      "metadata": {
        "description": "Object ID of signed-in deployer for RBAC assignments"
      }
    },
    "vpnClientAddressPool": {
      "type": "string",
      "defaultValue": "172.16.201.0/24",
      "metadata": {
        "description": "P2S VPN client address pool"
      }
    },
    "vnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.50.0.0/16",
      "metadata": {
        "description": "VNet CIDR"
      }
    },
    "privateEndpointSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.50.1.0/24",
      "metadata": {
        "description": "Private endpoint subnet CIDR"
      }
    },
    "dnsSubnetPrefix": {
      "type": "string",
      "defaultValue": "10.50.2.0/24",
      "metadata": {
        "description": "DNS forwarder subnet CIDR"
