    },
    {
      "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
      "apiVersion": "2020-06-01",
      "name": "[format('{0}/{1}', 'privatelink.search.windows.net', 'link-vnet-search01')]",
      "location": "global",
      "properties": {
