# This file documents the expected variables.
# The actual env/.env is written automatically by 01_deploy_infra.ipynb
# after the Bicep deployment completes. Never commit env/.env.
#
# New Foundry (AIServices kind) endpoint format:
#   https://<account-name>.services.ai.azure.com/
# (Classic Azure OpenAI used: https://<account-name>.openai.azure.com/)

AZURE_AI_ENDPOINT=https://<account-name>.services.ai.azure.com/
AZURE_AI_API_KEY=<api-key>
AZURE_AI_DEPLOYMENT=chat
AZURE_ACCOUNT_NAME=<account-name>
AZURE_RESOURCE_GROUP=<resource-group-name>
