# This file documents the expected environment variables.
# The actual env/.env is written automatically by 01_deploy_infra.ipynb
# after Bicep deployment. Never commit env/.env.

# Azure OpenAI (classic)
AZURE_OPENAI_ENDPOINT=https://aoai<demoid>uks.openai.azure.com/
AZURE_OPENAI_API_KEY=<openai-api-key>
AZURE_OPENAI_DEPLOYMENT=chat4o
AZURE_OPENAI_SECONDARY_DEPLOYMENT=chat51
AZURE_OPENAI_API_VERSION=2024-10-21

# APIM gateway (primary endpoint used by test/evaluation notebooks)
APIM_ENDPOINT=https://apim-<demoid>-uks.azure-api.net
APIM_CHAT_COMPLETIONS_PATH=/openai/chat/completions
APIM_API_KEY=<apim-subscription-key>

# Azure resource metadata
AZURE_RESOURCE_GROUP=rg-<demoid>-uks
AZURE_OPENAI_ACCOUNT_NAME=aoai<demoid>uks
AZURE_APIM_NAME=apim-<demoid>-uks

# Evaluation paths
EVAL_DATASET_PATH=../data/eval-prompts.jsonl
EVAL_OUTPUT_PATH=../outputs/eval-results.json
